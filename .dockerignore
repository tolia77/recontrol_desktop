# Keep the Linux installer build context lean. The build only needs
# ReControl.Desktop/, scripts/, installer/, and ReControl.Desktop/.env.prod.

# Build/output dirs (regenerated inside the container)
**/bin
**/obj
publish*/
staging/
dist/

# Dependencies and host-specific native libs
**/node_modules
ReControl.Desktop/ffmpeg/

# Projects not part of the desktop app build
Spikes/
ReControl.Desktop.Tests/

# VCS / editor / OS cruft
.git
.vs
.vscode
**/*.user
.DS_Store
