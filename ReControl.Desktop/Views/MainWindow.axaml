<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ReControl.Desktop.ViewModels"
        x:Class="ReControl.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="ReControl"
        Width="400"
        Height="300">

    <DockPanel Margin="16">

        <!-- Top bar with status and logout -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <TextBlock Grid.Column="0"
                       Text="{Binding ConnectionStatus}"
                       VerticalAlignment="Center"
                       FontSize="14"
                       FontWeight="SemiBold" />
            <Button Grid.Column="1"
                    Content="Logout"
                    Command="{Binding LogoutCommand}"
                    Padding="12,6" />
        </Grid>

        <!-- Device info -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock FontSize="12" Foreground="Gray">
                <Run Text="Device ID: " />
                <Run Text="{Binding DeviceId}" />
            </TextBlock>
        </StackPanel>

        <!-- Main content area: centered status -->
        <TextBlock Text="{Binding ConnectionStatus}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="18"
                   Foreground="Gray" />

    </DockPanel>
</Window>
