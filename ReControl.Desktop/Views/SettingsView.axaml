<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReControl.Desktop.ViewModels"
             x:Class="ReControl.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
        <TextBlock Text="Settings"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Coming in Plan 03"
                   FontSize="13"
                   Foreground="{DynamicResource SubtleTextBrush}"
                   HorizontalAlignment="Center"/>
    </StackPanel>
</UserControl>
