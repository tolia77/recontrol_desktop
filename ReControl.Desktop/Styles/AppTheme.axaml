<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Custom resource brushes for app-specific colors -->
    <Style>
        <Style.Resources>
            <ResourceDictionary>
                <ResourceDictionary.ThemeDictionaries>
                    <ResourceDictionary x:Key="Dark">
                        <SolidColorBrush x:Key="StatusConnectedBrush" Color="#22C55E"/>
                        <SolidColorBrush x:Key="StatusConnectingBrush" Color="#EAB308"/>
                        <SolidColorBrush x:Key="StatusDisconnectedBrush" Color="#EF4444"/>
                        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#0B0E17"/>
                        <SolidColorBrush x:Key="SidebarSelectedBrush" Color="#1E293B"/>
                        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1A1D2E"/>
                        <SolidColorBrush x:Key="CardBorderBrush" Color="#334155"/>
                        <SolidColorBrush x:Key="SubtleTextBrush" Color="#94A3B8"/>
                        <SolidColorBrush x:Key="SignUpLinkBrush" Color="#818CF8"/>
                    </ResourceDictionary>
                </ResourceDictionary.ThemeDictionaries>
            </ResourceDictionary>
        </Style.Resources>
    </Style>
</Styles>
